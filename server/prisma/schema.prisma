// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============ 枚举定义 ============

// 账户角色
enum Role {
  HUIZHANG // 会长
  CHAOGUAN // 超管
  GUANLI // 管理
}

// 账户状态
enum AccountStatus {
  ACTIVE // 正常
  DISABLED // 禁用
}

// 历史操作类型
enum HistoryAction {
  UPDATE // 修改
  DELETE // 删除
}

// 统计周期
enum StatCycle {
  WEEK // 按周统计
  MONTH // 按月统计
}

// 通知类型
enum NotificationType {
  RANK_PUBLISH // 排名公布
  RULE_CHANGE // 规则变更
  DATA_CHANGE // 数据变更
}

// ============ 账户表 ============

model Account {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  passwordHash String
  role         Role
  branchId     Int?
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  branch             Branch?       @relation(fields: [branchId], references: [id])
  createdDataRecords DataRecord[]  @relation("DataRecordCreatedBy")
  modifiedHistories  DataHistory[] @relation("DataHistoryModifier")
  loginRecords       LoginRecord[] @relation("AccountLoginRecords")

  @@index([branchId])
}

// ============ 分部表 ============

model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  statCycle StatCycle @default(WEEK)
  createdAt DateTime  @default(now())

  accounts          Account[]
  personnelBranches PersonnelBranch[]
  dataRecords       DataRecord[]
  rewardRules       RewardRule?
  notifications     Notification[]
}

// ============ 人员表 ============

model Personnel {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  personnelBranches PersonnelBranch[]
  dataRecords       DataRecord[]
}

// ============ 人员-分部关联表 ============

model PersonnelBranch {
  id          Int      @id @default(autoincrement())
  personnelId Int
  branchId    Int
  createdAt   DateTime @default(now())

  personnel Personnel @relation(fields: [personnelId], references: [id])
  branch    Branch    @relation(fields: [branchId], references: [id])

  @@unique([personnelId, branchId])
  @@index([branchId])
}

// ============ 数据记录表 ============

model DataRecord {
  id          Int      @id @default(autoincrement())
  personnelId Int
  branchId    Int
  weekStart   DateTime
  sg          Int      @default(0)
  mx          Int      @default(0)
  qm          Int      @default(0)
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personnel Personnel     @relation(fields: [personnelId], references: [id])
  branch    Branch        @relation(fields: [branchId], references: [id])
  creator   Account       @relation("DataRecordCreatedBy", fields: [createdBy], references: [id])
  histories DataHistory[]

  // 单字段索引
  @@index([personnelId])
  @@index([branchId])
  @@index([weekStart])
  @@index([createdBy])
  // 组合索引：常用查询场景（按周+分部查询、按周+分部+人员查询）
  @@index([weekStart, branchId])
  @@index([weekStart, branchId, personnelId])
  @@index([branchId, personnelId])
}

// ============ 修改历史表 ============

model DataHistory {
  id         Int           @id @default(autoincrement())
  recordId   Int?
  modifierId Int
  modifyTime DateTime      @default(now())
  action     HistoryAction
  field      String?
  oldValue   String?
  newValue   String?

  record   DataRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)
  modifier Account     @relation("DataHistoryModifier", fields: [modifierId], references: [id])

  @@index([recordId])
  @@index([modifierId])
}

// ============ 奖励规则表 ============

model RewardRule {
  id             Int      @id @default(autoincrement())
  branchId       Int      @unique
  sgRatio        Int      @default(3)
  qmRatio        Int      @default(3)
  rank1Reward    Int      @default(100)
  rank2Reward    Int      @default(80)
  rank3Reward    Int      @default(60)
  maixuThreshold Int      @default(40)
  maixuReward    Int      @default(52)
  // 麦序最低标准：启用后麦序未达到此值则不计福利（基础福利与排名奖励均置0）
  maixuMinStandard Int    @default(0)
  maixuMinEnabled  Boolean @default(false)
  // 各奖励项开关（true=启用，false=该奖励项不计入福利）
  sgEnabled      Boolean  @default(true)
  qmEnabled      Boolean  @default(true)
  rankEnabled    Boolean  @default(true)
  maixuEnabled   Boolean  @default(true)
  // 排名奖金与麦序达标奖励是否叠加
  // true：前3名达标时排名奖金 + 麦序达标奖励叠加
  // false：前3名只拿排名奖金，不叠加麦序达标奖励
  stackRankAndMaixu Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
}

// ============ 通知表 ============

model Notification {
  id        Int              @id @default(autoincrement())
  branchId  Int
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

// ============ 登录记录表 ============

model LoginRecord {
  id        Int      @id @default(autoincrement())
  accountId Int
  loginTime DateTime @default(now())
  userAgent String?

  account Account @relation("AccountLoginRecords", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([loginTime])
}
