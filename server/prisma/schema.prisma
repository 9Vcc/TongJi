// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ============ 枚举定义 ============

// 账户角色
enum Role {
  HUIZHANG // 会长
  CHAOGUAN // 超管
  GUANLI // 管理
}

// 账户状态
enum AccountStatus {
  ACTIVE // 正常
  DISABLED // 禁用
}

// 历史操作类型
enum HistoryAction {
  CREATE // 录入
  UPDATE // 修改
  DELETE // 删除
}

// 统计周期
enum StatCycle {
  WEEK // 按周统计
  MONTH // 按月统计
}

// 通知类型
enum NotificationType {
  RANK_PUBLISH // 排名公布
  RULE_CHANGE // 规则变更
  DATA_CHANGE // 数据变更
}

// ============ 账户表 ============

model Account {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  nickname     String?
  passwordHash String
  role         Role
  branchId     Int?
  // 主合厅组 ID（可空）：当主厅为合厅组时设置，此时 branchId 可为 null
  mainGroupId  Int?
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  branch             Branch?       @relation(fields: [branchId], references: [id])
  mainGroup          BranchGroup?  @relation(fields: [mainGroupId], references: [id], onDelete: SetNull)
  createdDataRecords DataRecord[]  @relation("DataRecordCreatedBy")
  modifiedHistories  DataHistory[] @relation("DataHistoryModifier")
  loginRecords       LoginRecord[] @relation("AccountLoginRecords")
  deductions        Deduction[]   @relation("DeductionCreatedBy")
  mxTimeSlotRecords  MxTimeSlotRecord[] @relation("MxTimeSlotRecordCreator")
  fines              Fine[]         @relation("FineCreatedBy")
  accountBranches    AccountBranch[]
  accountGroups      AccountGroup[]

  @@index([branchId])
}

// ============ 账户-分部关联表 ============
// 仅超管支持多厅授权：主厅为 Account.branchId，额外授权厅存储在此表
// 管理角色仍为单厅（Account.branchId），不使用此表

model AccountBranch {
  id        Int      @id @default(autoincrement())
  accountId Int
  branchId  Int
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([accountId, branchId])
  @@index([branchId])
}

// ============ 账户-合厅组关联表 ============
// 仅超管支持合厅组授权：会长可为超管授权可查看的合厅组
// 管理角色不使用此表

model AccountGroup {
  id        Int      @id @default(autoincrement())
  accountId Int
  groupId   Int
  createdAt DateTime @default(now())

  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  group   BranchGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([accountId, groupId])
  @@index([groupId])
}

// ============ 分部表 ============

model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  statCycle StatCycle @default(WEEK)
  // 厅关闭状态：True=已关闭（公开看板/排名不显示，禁止录入新数据），false=正常
  closed    Boolean   @default(false)
  // 所属合厅组 ID（可空，未参与合厅则为 null）
  groupId   Int?
  createdAt DateTime  @default(now())

  accounts          Account[]
  accountBranches   AccountBranch[]
  personnelBranches PersonnelBranch[]
  dataRecords       DataRecord[]
  rewardRules       RewardRule?
  namingLevels      NamingLevel[]
  notifications     Notification[]
  deductions        Deduction[]
  timeSlotMultipliers TimeSlotMultiplier[]
  // 所属合厅组（参与合厅时关联）
  group             BranchGroup? @relation(fields: [groupId], references: [id])

  @@index([groupId])
}

// ============ 合厅组表 ============
// 用于将多个厅合并为一组进行统一管理（录入时查看多人、导出时分别导出）
// 仅会长可创建/解散合厅组

model BranchGroup {
  id        Int      @id @default(autoincrement())
  name      String   // 合厅名称
  createdAt DateTime @default(now())

  branches Branch[]
  accounts AccountGroup[]
  mainAccounts Account[]
}

// ============ 冠名等级表（每厅独立配置）============
// 仅按月统计的厅启用冠名，录入收光时按阈值整除转换为冠名，余数计入收光
// 多等级时按 threshold 降序逐级扣减转换

model NamingLevel {
  id        Int    @id @default(autoincrement())
  branchId  Int
  name      String // 等级名称，如"周冠"、"月冠"
  threshold Int    // 收光阈值（达到此值转换1个冠名）
  reward    Decimal @default(0) @db.Decimal(10, 2) // 每个冠名的福利金额（支持两位小数）
  sortOrder Int    @default(0) // 排序值（大在前，用于逐级扣减顺序）
  createdAt DateTime @default(now())

  branch  Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  records DataRecordNaming[]

  @@index([branchId])
}

// ============ 人员表 ============

model Personnel {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  personnelBranches PersonnelBranch[]
  dataRecords       DataRecord[]
  deductions        Deduction[]
}

// ============ 人员-分部关联表 ============

model PersonnelBranch {
  id          Int      @id @default(autoincrement())
  personnelId Int
  branchId    Int
  createdAt   DateTime @default(now())

  personnel Personnel @relation(fields: [personnelId], references: [id])
  branch    Branch    @relation(fields: [branchId], references: [id])

  @@unique([personnelId, branchId])
  @@index([branchId])
}

// ============ 数据记录表 ============

model DataRecord {
  id          Int      @id @default(autoincrement())
  personnelId Int
  branchId    Int
  weekStart   DateTime
  sg          Int      @default(0)
  mx          Float    @default(0)
  qm          Int      @default(0)
  zcDays      Int      @default(0)
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  remark       String?

  personnel Personnel     @relation(fields: [personnelId], references: [id])
  branch    Branch        @relation(fields: [branchId], references: [id])
  creator   Account       @relation("DataRecordCreatedBy", fields: [createdBy], references: [id])
  histories DataHistory[]
  namings   DataRecordNaming[]
  mxTimeSlotRecords MxTimeSlotRecord[]

  // 单字段索引
  @@index([personnelId])
  @@index([branchId])
  @@index([weekStart])
  @@index([createdBy])
  // 组合索引：常用查询场景（按周+分部查询、按周+分部+人员查询）
  @@index([weekStart, branchId])
  @@index([weekStart, branchId, personnelId])
  @@index([branchId, personnelId])
}

// ============ 修改历史表 ============

model DataHistory {
  id         Int           @id @default(autoincrement())
  recordId   Int?
  modifierId Int
  modifyTime DateTime      @default(now())
  action     HistoryAction
  field      String?
  oldValue   String?
  newValue   String?
  remark     String?

  record   DataRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)
  modifier Account     @relation("DataHistoryModifier", fields: [modifierId], references: [id])

  @@index([recordId])
  @@index([modifierId])
}

// ============ 数据记录-冠名关联表 ============
// 存储每条 DataRecord 各等级冠名数量（累加）

model DataRecordNaming {
  id        Int @id @default(autoincrement())
  recordId  Int
  levelId   Int
  count     Int @default(0)

  record DataRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  level  NamingLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([recordId, levelId])
  @@index([recordId])
  @@index([levelId])
}

// ============ 奖励规则表 ============

model RewardRule {
  id             Int      @id @default(autoincrement())
  branchId       Int      @unique
  sgRatio        Int      @default(3)
  qmRatio        Int      @default(3)
  rank1Reward    Int      @default(100)
  rank2Reward    Int      @default(80)
  rank3Reward    Int      @default(60)
  maixuThreshold Int      @default(40)
  maixuReward    Int      @default(52)
  // 麦序最低标准：启用后麦序未达到此值则不计福利（基础福利与排名奖励均置0）
  maixuMinStandard Int    @default(0)
  maixuMinEnabled  Boolean @default(false)
  // 各奖励项开关（true=启用，false=该奖励项不计入福利）
  sgEnabled      Boolean  @default(true)
  qmEnabled      Boolean  @default(true)
  rankEnabled    Boolean  @default(true)
  maixuEnabled   Boolean  @default(true)
  // 排名奖金与麦序达标奖励是否叠加
  // true：前3名达标时排名奖金 + 麦序达标奖励叠加
  // false：前3名只拿排名奖金，不叠加麦序达标奖励
  stackRankAndMaixu Boolean @default(true)
  // 主持天数福利：启用后按录入的主持天数 × 每日福利计入基础福利
  zcEnabled   Boolean  @default(false)
  zcDayReward Int      @default(0)
  // 时间段倍率功能开关：启用后添加数据时用日期+时间段选择替代备注，麦序按时间段倍率换算
  mxSlotEnabled Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
}

// ============ 通知表 ============

model Notification {
  id        Int              @id @default(autoincrement())
  branchId  Int
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

// ============ 登录记录表 ============

model LoginRecord {
  id        Int      @id @default(autoincrement())
  accountId Int
  loginTime DateTime @default(now())
  userAgent String?

  account Account @relation("AccountLoginRecords", fields: [accountId], references: [id])

  @@index([accountId])
  @@index([loginTime])
}

// ============ 福利扣减表 ============
// 按周期记录每个人员的福利扣减金额，最终福利 = 原福利 - deduction
// periodStart：周统计厅=该周周一，月统计厅=该月1号
// 与 DataRecord 解耦，避免月统计厅按周累加扣减

model Deduction {
  id          Int      @id @default(autoincrement())
  branchId    Int
  personnelId Int
  periodStart DateTime
  amount      Int      @default(0)
  remark      String?  // 扣减备注（覆盖式存储，限100字）
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  personnel Personnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  creator   Account   @relation("DeductionCreatedBy", fields: [createdBy], references: [id])

  @@unique([branchId, personnelId, periodStart])
  @@index([branchId, periodStart])
  @@index([personnelId])
}

// ============ 时间段倍率表（每厅独立配置）============
// 12个时间段（0-2, 2-4, ..., 22-24），每个时间段可设置麦序倍率
// 启用 mxSlotEnabled 后，添加数据时麦序 = 原始麦序 × 时间段倍率

model TimeSlotMultiplier {
  id         Int    @id @default(autoincrement())
  branchId   Int
  slotIndex  Int    // 时间段索引 0-11（0=0-2点, 1=2-4点, ..., 11=22-24点）
  multiplier Float  @default(1) // 麦序倍率

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, slotIndex])
  @@index([branchId])
}

// ============ 时间段录入明细表 ============
// 每次通过"添加数据"弹窗录入的时间段明细记录
// 关联 DataRecord，存储日期、时间段、原始麦序、倍率快照、换算后麦序及收光/全麦/主持

model MxTimeSlotRecord {
  id          Int      @id @default(autoincrement())
  recordId    Int      // 关联 DataRecord
  slotDate    DateTime // 录入日期（如7月16日 00:00:00）
  slotIndex   Int      // 时间段索引 0-11
  rawMx       Int      @default(0) // 原始麦序值（用户输入）
  multiplier  Float    @default(1) // 录入时的倍率快照
  convertedMx Float    @default(0) // 换算后麦序 = rawMx × multiplier
  sg          Int      @default(0) // 收光（不参与倍率）
  qm          Int      @default(0) // 全麦（不参与倍率）
  zcDays      Int      @default(0) // 主持天数（不参与倍率）
  createdBy   Int
  createdAt   DateTime @default(now())

  record  DataRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  creator Account    @relation("MxTimeSlotRecordCreator", fields: [createdBy], references: [id])

  @@index([recordId])
  @@index([slotDate])
  @@index([recordId, slotDate, slotIndex])
}

// ============ 罚款人员表（独立于数据录入人员，不与厅同步）============
model FinePersonnel {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fines Fine[]

  @@index([name])
}

// ============ 罚款记录表 ============
// 独立于厅和 DataRecord，仅会长可管理
// reasonType: 罚款原因分类（LATE=迟到, VIOLATION=违规, OTHER=其他）
model Fine {
  id          Int      @id @default(autoincrement())
  personnelId Int
  amount      Int      // 罚款金额（正整数）
  fineDate    DateTime // 罚款日期
  reasonType  String   @default("OTHER") // 原因分类：LATE/VIOLATION/OTHER
  remark      String?  // 备注
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personnel FinePersonnel @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  creator   Account       @relation("FineCreatedBy", fields: [createdBy], references: [id])

  @@index([personnelId])
  @@index([fineDate])
  @@index([reasonType])
}
