# ============================================
# 统计系统环境变量配置模板
# ============================================
# 使用方法：复制此文件为 .env 并按需修改
#   cp .env.example .env

# ---------- 数据库 ----------
# MariaDB 连接字符串
# 格式：mariadb://用户名:密码@主机:端口/数据库名
# 本地开发：mariadb://tongji:tongji123@127.0.0.1:3306/tongji
# Docker Compose：mariadb://tongji:tongji123@mariadb:3306/tongji
DATABASE_URL="mariadb://tongji:tongji123@127.0.0.1:3306/tongji"

# ---------- 安全 ----------
# JWT 签名密钥
# 生产环境必须设置：至少 32 字节的强随机字符串
# 可用命令生成：openssl rand -base64 48
JWT_SECRET="change-me-to-a-strong-random-secret"

# JWT 过期时间（如 7d / 24h / 1h）
JWT_EXPIRES_IN="7d"

# ---------- 应用 ----------
# 运行环境：development | production
NODE_ENV="development"
