# ============================================
# 统计系统环境变量配置模板
# ============================================
# 使用方法：复制此文件为 .env 并按需修改
#   cp .env.example .env

# ---------- 数据库 ----------
# MariaDB 连接字符串
# 注意：Prisma CLI 仅识别 mysql:// 协议（MariaDB 兼容 MySQL 协议），不可使用 mariadb://
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://tongji:tongji123@127.0.0.1:3306/tongji"

# ---------- 安全 ----------
# JWT 签名密钥
# 生产环境必须设置：至少 32 字节的强随机字符串
# 可用命令生成：openssl rand -base64 48
JWT_SECRET="change-me-to-a-strong-random-secret"

# JWT 过期时间（如 7d / 24h / 1h）
JWT_EXPIRES_IN="7d"

# ---------- 种子接口（/api/seed）安全配置 ----------
# 生产环境下首次初始化 admin 账户所需密码
# - 生产环境（NODE_ENV=production）admin 不存在时，必须设置此项才能创建，否则接口返回 500
# - 生产环境 admin 已存在时接口一律返回 403 拒绝
# - 非生产环境未设置时回退到默认密码 admin123 以便开发测试
# 建议生成强随机密码：openssl rand -base64 24
SEED_ADMIN_PASSWORD=""

# ---------- 应用 ----------
# 运行环境：development | production
NODE_ENV="development"

# ---------- CORS 跨域配置 ----------
# 允许的前端来源域名白名单，多个用逗号分隔（不要含空格，会自动 trim）
# 示例：https://ldr.9vcc.top,http://localhost:5173
# 生产环境必须配置；留空（或不设置）时将放行所有来源（仅适用于开发环境）
CORS_ORIGINS="https://ldr.9vcc.top,http://localhost:5173"

# ---------- 速率限制 ----------
# 全局默认限流：每个 IP 每分钟最多请求次数
# 默认 500/分钟：已认证用户正常并发加载、切页不会误触；
# 登录接口单独限制为每分钟 5 次；公开接口限制为每分钟 60 次
# 生产环境可根据实际流量调优
RATE_LIMIT_MAX="500"

# 全局默认限流时间窗口（支持人类可读格式，如 '1 minute'、'30 seconds'、'2 minutes'）
RATE_LIMIT_WINDOW="1 minute"
