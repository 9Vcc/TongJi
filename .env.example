# ============================================
# Docker Compose 环境变量配置
# ============================================
# 使用方法：复制此文件为 .env 并按需修改
#   cp .env.example .env
#
# docker-compose.yml 会自动读取同目录下的 .env 文件
# ============================================

# ---------- MariaDB 数据库配置 ----------
# root 密码（仅用于数据库管理，应用不使用）
MARIADB_ROOT_PASSWORD=root123

# 应用数据库名
MARIADB_DATABASE=tongji

# 应用数据库用户名
MARIADB_USER=tongji

# 应用数据库密码
MARIADB_PASSWORD=tongji123

# MariaDB 对外暴露端口（如不需要外部访问可注释掉 ports 配置）
MARIADB_PORT=3306

# ---------- 应用配置 ----------
# 对外暴露的 HTTP 端口
APP_PORT=80

# JWT 签名密钥（生产环境必须修改！）
# 生成命令：openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-random-secret

# JWT 过期时间
JWT_EXPIRES_IN=7d
