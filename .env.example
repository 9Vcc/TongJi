# ============================================
# Docker Compose 环境变量配置
# ============================================
# 本编排仅启动应用容器，数据库（MariaDB）请使用已独立搭建的实例
#
# 使用方法：复制此文件为 .env 并按需修改
#   cp .env.example .env
#
# docker-compose.yml 会自动读取同目录下的 .env 文件
# ============================================

# ---------- MariaDB 数据库连接 ----------
# 完整连接串，格式：mysql://用户名:密码@主机:端口/数据库名
# 注意：必须使用 mysql:// 协议（Prisma CLI 不识别 mariadb://，MariaDB 兼容 MySQL 协议）
#
# 主机地址填写说明：
#   - MariaDB 与 Docker 同宿主机：host.docker.internal（推荐）或 172.17.0.1
#   - MariaDB 在远程服务器：填写远程服务器 IP，如 192.168.1.100
#   - MariaDB 使用 Docker 独立容器且与本编排共用网络：填写容器名或服务名
#
# 重要：
#   1. 确保 MariaDB 已创建对应数据库和用户
#   2. 确保 MariaDB 允许从 Docker 容器（非 127.0.0.1）连接
#      - 检查 bind-address 配置（建议改为 0.0.0.0）
#      - 检查用户授权主机（建议 'tongji'@'%' 或指定 Docker 网段）
DATABASE_URL=mysql://user:password@host:3306/tongji

# ---------- 应用配置 ----------
# 对外暴露的 HTTP 端口
APP_PORT=80

# JWT 签名密钥（生产环境必须修改！）
# 生成命令：openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-random-secret

# JWT 过期时间
JWT_EXPIRES_IN=7d

# ---------- CORS 跨域配置 ----------
# 允许的前端来源域名白名单，多个用逗号分隔（不要含空格，会自动 trim）
# 示例：https://ldr.9vcc.top,http://localhost:5173
# 生产环境必须配置；留空（或不设置）时将放行所有来源（仅适用于开发环境）
CORS_ORIGINS=https://ldr.9vcc.top,http://localhost:5173

# ---------- 种子接口（/api/seed）安全配置 ----------
# 生产环境下首次初始化 admin 账户所需密码
# - 生产环境（NODE_ENV=production）admin 不存在时，必须设置此项才能创建，否则接口返回 500
# - 生产环境 admin 已存在时接口一律返回 403 拒绝
# - 非生产环境未设置时回退到默认密码 admin123 以便开发测试
# 建议生成强随机密码：openssl rand -base64 24
SEED_ADMIN_PASSWORD=
